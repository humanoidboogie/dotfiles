#!/bin/bash

# setup niri dotfiles
rm ~/.config/niri/config.kdl
rm ~/.config/niri/dms/binds.kdl
stow -t ~ niri

# setup DMS dotfiles
rm ~/.config/DankMaterialShell/settings.json
stow -t ~ dms

# setup nvim dotfiles
rm -rf ~/.config/nvim
stow -t ~ nvim

# setup kitty dotfiles
rm ~/.config/kitty/kitty.conf
stow -t ~ kitty
