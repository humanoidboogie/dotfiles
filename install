#!/bin/bash

# niri
rm ~/.config/niri/config.kdl
rm ~/.config/niri/dms/binds.kdl
stow -t ~ niri

# DMS
rm ~/.config/DankMaterialShell/settings.json
stow -t ~ dms

# nvim
rm -rf ~/.config/nvim
stow -t ~ nvim

# kitty
rm ~/.config/kitty/kitty.conf
stow -t ~ kitty

# bashrc
rm ~/.bashrc
stow -t ~ bashrc
