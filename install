#!/bin/bash

# niri
rm ~/.config/niri/config.kdl
rm ~/.config/niri/dms/binds.kdl
stow -t ~ niri

# DMS
rm ~/.config/DankMaterialShell/settings.json
stow -t ~ dms

# nvim
rm -rf ~/.config/nvim
stow -t ~ nvim

# ghostty
rm ~/.config/ghostty/config
stow -t ~ ghostty

# bashrc
rm ~/.bashrc
stow -t ~ bashrc
